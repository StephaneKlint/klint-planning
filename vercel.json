{
  "version": 2,
  "buildCommand": "cd packages/frontend && pnpm install && pnpm run build",
  "outputDirectory": "packages/frontend/.next",
  "env": {
    "DATABASE_URL": "@database_url",
    "KV_REST_API_URL": "@kv_rest_api_url",
